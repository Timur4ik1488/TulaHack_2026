# Docker / compose: задайте DATABASE_URL или POSTGRES_* (см. корневой .env рядом с compose.yml).
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Локальный Postgres в compose (сервис db): POSTGRES_HOST=db POSTGRES_PORT=5432
# Удалённый сервер: POSTGRES_HOST=150.241.103.30 POSTGRES_PORT=5435

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Telegram (internal API + бот; см. корневой .env и compose.yml → сервис tg_bot)
# TELEGRAM_INTERNAL_SECRET=тот-же-секрет-что-в-корневом-.env
# TELEGRAM_BOT_TOKEN=
# PUBLIC_SITE_URL=http://localhost
