# Скопируйте в .env в корне репозитория (рядом с compose.yml).
# Docker Compose читает этот файл для backend, tg_bot и др.

# --- PostgreSQL (как в compose для backend) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=

# =============================================================================
# DEPLOY (прод, не включать на локалке — только скопировать нужные строки в .env)
# Сервер приложений / БД: хост 150.241.103.30, PostgreSQL на порту 5435.
# Раскомментируйте и подставьте реальные USER/PASSWORD/DB при выкладке:
#POSTGRES_HOST=150.241.103.30
#POSTGRES_PORT=5435
#POSTGRES_USER=
#POSTGRES_PASSWORD=
#POSTGRES_DB=
# Либо одной строкой (asyncpg), то же хост/порт:
#DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@150.241.103.30:5435/DBNAME
#
# Фронт по IP (nginx на этом же хосте или за прокси):
#PUBLIC_SITE_URL=http://150.241.103.30
# Для HTTPS позже: PUBLIC_SITE_URL=https://ваш-домен.ru
#
# Прод: BOOTSTRAP_ADMIN=false после первого входа админа.
#BOOTSTRAP_ADMIN=false
#
# Прод: куки только по HTTPS (локально оставьте как в дефолте config):
#COOKIE_SECURE=true
#COOKIE_SAMESITE=none
#
# CORS: в backend нужен список с origin прод-фронта (см. комментарии в app/core/config.py).
# =============================================================================

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# --- Telegram-бот (сервис tg_bot в compose.yml) ---
# Токен от @BotFather (достаточно одного из двух имён):
TELEGRAM_BOT_TOKEN=
# BOT_TOKEN=

# Общий секрет бота и API; должен совпадать с TELEGRAM_INTERNAL_SECRET у backend (тот же .env).
TELEGRAM_INTERNAL_SECRET=

# Опционально: username бота без @ (деплой, ссылки)
# TELEGRAM_BOT_USERNAME=HackSwipeBot

# Опционально: чат админа для служебных сообщений
# TELEGRAM_ADMIN_CHAT_ID=

# Ссылки в ответах бота (фронт). Для Docker с nginx на хосте часто:
# PUBLIC_SITE_URL=http://localhost
PUBLIC_SITE_URL=http://localhost
