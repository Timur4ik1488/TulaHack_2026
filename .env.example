# Скопируйте в .env в корне репозитория (рядом с compose.yml).
# Docker Compose читает этот файл для backend, tg_bot и др.

# --- PostgreSQL (как в compose для backend) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# --- Telegram-бот (сервис tg_bot в compose.yml) ---
# Токен от @BotFather (достаточно одного из двух имён):
TELEGRAM_BOT_TOKEN=
# BOT_TOKEN=

# Общий секрет бота и API; должен совпадать с TELEGRAM_INTERNAL_SECRET у backend (тот же .env).
TELEGRAM_INTERNAL_SECRET=

# Опционально: username бота без @ (деплой, ссылки)
# TELEGRAM_BOT_USERNAME=HackSwipeBot

# Опционально: чат админа для служебных сообщений
# TELEGRAM_ADMIN_CHAT_ID=

# Ссылки в ответах бота (фронт). Для Docker с nginx на хосте часто:
# PUBLIC_SITE_URL=http://localhost
PUBLIC_SITE_URL=http://localhost
