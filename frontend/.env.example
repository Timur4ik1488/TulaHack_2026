# Оставьте пустым для dev с Vite proxy (запросы на тот же origin → /api → localhost:8000).
# Или укажите полный URL бэкенда, например: http://127.0.0.1:8000
VITE_API_URL=

# --- DEPLOY (прод; не включать при локальной разработке с Vite) ---
# Если фронт открывают с другого origin, чем API — задать базовый URL API (с протоколом, без завершающего /):
# Сервер 150.241.103.30: при отдаче фронта и API с одного nginx часто VITE_API_URL оставляют пустым.
# Отдельный билд фронта, ходящий на API по IP:
#VITE_API_URL=http://150.241.103.30
# Или только бэкенд на другом порту (пример):
#VITE_API_URL=http://150.241.103.30:8000
# Telegram username для ссылки в футере (если отличается от дефолта):
#VITE_TELEGRAM_BOT_USERNAME=YourBotName
